generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnalysisStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

model Analysis {
  id               String         @id @default(cuid())
  status           AnalysisStatus @default(UPLOADING)
  originalFilename String
  storedFilename   String?
  mimeType         String?
  fileSizeBytes    Int?
  failureReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
